# CapitalLens AI environment
# Demo mode is enabled automatically when OPENAI_API_KEY is missing.
DEMO_MODE=true

# Optional OpenAI-compatible LLM polishing
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional news provider hook
NEWS_API_KEY=

# Optional SEC/EDGAR user agent for future live filing expansion
SEC_USER_AGENT=CapitalLensAI/1.0 contact@example.com

# Optional local database path
CAPITALLENS_DB_PATH=capital_lens_watchlist.db

